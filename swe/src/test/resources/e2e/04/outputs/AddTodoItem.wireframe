<wireframe package="todo" name="AddTodoItem">
  <container name="AddTodoItem" direction="top_to_bottom">
    <children>
      <affordance name="AddTodoItem">
        <inputField name="Task" type="text"/>
        <inputField name="DueDate" type="datetime"/>
      </affordance>
    </children>
  </container>
</wireframe>
